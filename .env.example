# Base de datos PostgreSQL (Supabase)
# Sustituye [YOUR-PASSWORD] por tu contraseña de Supabase en ambas líneas
DATABASE_URL="postgresql://postgres.pdljptpnxklnvqfybwji:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.pdljptpnxklnvqfybwji:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

# NextAuth (panel de administración)
# Genera un valor aleatorio largo, por ejemplo con: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Administrador inicial (se crea al ejecutar `npm run db:seed`)
ADMIN_EMAIL="admin@tu-hostal.com"
ADMIN_PASSWORD="cambia-esta-clave"

# URL pública de la app (sin / al final). En producción, la URL real de tu dominio.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Redsys (TPV Virtual) — datos que te entrega tu banco al activar el servicio
REDSYS_MERCHANT_CODE=""
REDSYS_TERMINAL="1"
REDSYS_CLAVE_SECRETA=""
# "pruebas" mientras testeas, "produccion" cuando esté todo validado
REDSYS_ENTORNO="pruebas"
