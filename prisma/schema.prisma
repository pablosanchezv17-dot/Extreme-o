generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TipoHabitacion {
  PRIVADA
  COMPARTIDA
  DORMITORIO
  SUITE
}

enum EstadoReserva {
  PENDIENTE_PAGO
  CONFIRMADA
  PAGO_FALLIDO
  CANCELADA
  COMPLETADA
}

// ── Clientes (NextAuth compatible) ─────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  telefono      String?
  creadoEn      DateTime  @default(now())

  reservas      Reserva[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Habitaciones ────────────────────────────────────────────────────────
model Habitacion {
  id             String         @id @default(cuid())
  nombre         String
  slug           String         @unique
  descripcion    String
  tipo           TipoHabitacion @default(PRIVADA)
  capacidad      Int
  precioPorNoche Decimal        @db.Decimal(10, 2)
  imagenes       String[]       @default([])
  comodidades    String[]       @default([])
  activa         Boolean        @default(true)
  creadaEn       DateTime       @default(now())
  actualizadaEn  DateTime       @updatedAt

  reservas       Reserva[]
  resenas        Resena[]
}

// ── Reservas ────────────────────────────────────────────────────────────
model Reserva {
  id              String        @id @default(cuid())
  numeroPedido    String        @unique

  habitacionId    String
  habitacion      Habitacion    @relation(fields: [habitacionId], references: [id])

  userId          String?
  user            User?         @relation(fields: [userId], references: [id])

  nombreHuesped   String
  emailHuesped    String
  telefonoHuesped String

  fechaEntrada    DateTime
  fechaSalida     DateTime
  noches          Int
  precioTotal     Decimal       @db.Decimal(10, 2)

  estado          EstadoReserva @default(PENDIENTE_PAGO)
  redsysAuthCode  String?
  redsysResponse  String?

  creadaEn        DateTime      @default(now())
  actualizadaEn   DateTime      @updatedAt

  resena          Resena?

  @@index([habitacionId, fechaEntrada, fechaSalida])
}

// ── Reseñas ─────────────────────────────────────────────────────────────
model Resena {
  id           String     @id @default(cuid())
  habitacionId String
  habitacion   Habitacion @relation(fields: [habitacionId], references: [id])

  reservaId    String     @unique
  reserva      Reserva    @relation(fields: [reservaId], references: [id])

  nombreHuesped String
  puntuacion    Int
  comentario    String

  aprobada     Boolean    @default(false)
  creadaEn     DateTime   @default(now())
}

// ── Mensajes de contacto ─────────────────────────────────────────────────
model MensajeContacto {
  id        String   @id @default(cuid())
  nombre    String
  email     String
  telefono  String?
  mensaje   String
  leido     Boolean  @default(false)
  creadoEn  DateTime @default(now())
}

// ── Administrador ────────────────────────────────────────────────────────
model Administrador {
  id           String   @id @default(cuid())
  email        String   @unique
  nombre       String
  passwordHash String
  creadoEn     DateTime @default(now())
}
